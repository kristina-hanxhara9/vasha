# ============================================================================
# VASHA — environment variables
# Copy this file to `.env.local` and fill in what you have. EVERYTHING is
# optional: with no keys at all, VASHA runs in a friendly DEMO mode.
# Each service "lights up" automatically when its keys are present.
# ============================================================================

# ---------- AI: Google Gemini (for real AI replies) -------------------------
# Get a FREE key at https://aistudio.google.com/apikey
# SECURITY: this key is SERVER-ONLY. It is read only inside /api routes and is
# NEVER sent to the browser. Do NOT rename it with a NEXT_PUBLIC_ prefix.
GEMINI_API_KEY=

# The Gemini model name — the ONE place to change it (no code changes needed).
# Default below. If your Google account returns a 404 for this model, switch to
# one you have access to. Safe fallback: gemini-2.5-flash
# Cheaper/high-volume: gemini-3.1-flash-lite  ·  Highest quality: gemini-3.1-pro
GEMINI_MODEL=gemini-3.5-flash

# Max tokens per reply (cost control). 2048 ≈ a long, friendly answer.
GEMINI_MAX_OUTPUT_TOKENS=2048

# ---------- Site ------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------- Supabase (auth, tiers, community, saved data) -------------------
# Without these, VASHA uses a local "guest" account and stores favourites/
# progress only in your browser. Create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SERVER-ONLY. Used by the Stripe webhook to upgrade a user's tier. Never expose.
SUPABASE_SERVICE_ROLE_KEY=

# ---------- Stripe (Premium subscriptions) ----------------------------------
# Without these, the Premium button shows a clearly-marked "demo upgrade".
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=

# ---------- Tier limits (server-enforced) -----------------------------------
# Free users get this many Sandbox runs per day. Premium = unlimited.
FREE_DAILY_SANDBOX_LIMIT=5
